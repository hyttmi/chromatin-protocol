from __future__ import annotations

import flatbuffers
import numpy as np

import flatbuffers
import typing

uoffset: typing.TypeAlias = flatbuffers.number_types.UOffsetTFlags.py_type

class Blob(object):
  @classmethod
  def GetRootAs(cls, buf: bytes, offset: int) -> Blob: ...
  @classmethod
  def GetRootAsBlob(cls, buf: bytes, offset: int) -> Blob: ...
  def Init(self, buf: bytes, pos: int) -> None: ...
  def NamespaceId(self, i: int) -> typing.List[int]: ...
  def NamespaceIdAsNumpy(self) -> np.ndarray: ...
  def NamespaceIdLength(self) -> int: ...
  def NamespaceIdIsNone(self) -> bool: ...
  def Pubkey(self, i: int) -> typing.List[int]: ...
  def PubkeyAsNumpy(self) -> np.ndarray: ...
  def PubkeyLength(self) -> int: ...
  def PubkeyIsNone(self) -> bool: ...
  def Data(self, i: int) -> typing.List[int]: ...
  def DataAsNumpy(self) -> np.ndarray: ...
  def DataLength(self) -> int: ...
  def DataIsNone(self) -> bool: ...
  def Ttl(self) -> int: ...
  def Timestamp(self) -> int: ...
  def Signature(self, i: int) -> typing.List[int]: ...
  def SignatureAsNumpy(self) -> np.ndarray: ...
  def SignatureLength(self) -> int: ...
  def SignatureIsNone(self) -> bool: ...
def BlobStart(builder: flatbuffers.Builder) -> None: ...
def BlobAddNamespaceId(builder: flatbuffers.Builder, namespaceId: uoffset) -> None: ...
def BlobStartNamespaceIdVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def BlobAddPubkey(builder: flatbuffers.Builder, pubkey: uoffset) -> None: ...
def BlobStartPubkeyVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def BlobAddData(builder: flatbuffers.Builder, data: uoffset) -> None: ...
def BlobStartDataVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def BlobAddTtl(builder: flatbuffers.Builder, ttl: int) -> None: ...
def BlobAddTimestamp(builder: flatbuffers.Builder, timestamp: int) -> None: ...
def BlobAddSignature(builder: flatbuffers.Builder, signature: uoffset) -> None: ...
def BlobStartSignatureVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def BlobEnd(builder: flatbuffers.Builder) -> uoffset: ...

